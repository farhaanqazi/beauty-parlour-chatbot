# ============================================================
# Beauty Parlour Chatbot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------
APP_NAME=Beauty Parlour Bot
API_PREFIX=/api/v1
ENVIRONMENT=development

# ------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ------------------------------------------------------------
# Get your database URL from Supabase Dashboard → Project Settings → Database
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DATABASE_PASSWORD_HERE@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?ssl=require

# ------------------------------------------------------------
# Redis (Required for session management)
# ------------------------------------------------------------
# Local: redis://localhost:6379/0
# Docker: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=86400
SESSION_TTL_SECONDS=86400

# ------------------------------------------------------------
# LLM Configuration (Groq)
# ------------------------------------------------------------
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3-1.5b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# CORS Origins (comma-separated, use * for development only)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------
# Telegram Bot Configuration
# ------------------------------------------------------------
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=8702280889:AAGR0AH_hqDR0W_y4Snrucqxl8k_U8oidBM
TELEGRAM_BOT_NAME=salon_chatbot

# ------------------------------------------------------------
# WhatsApp Business API Configuration
# ------------------------------------------------------------
# Get these from Meta Developer Dashboard
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ------------------------------------------------------------
# Webhook & Business Configuration
# ------------------------------------------------------------
# Public URL where webhooks will be received (use your domain for local dev)
# Example: http://farburgh.duckdns.org:8000
WEBHOOK_BASE_URL=http://farburgh.duckdns.org:8000
DEFAULT_SALON_SLUG=demo-beauty-palace
DEFAULT_TIMEZONE=Asia/Kolkata
MAX_SAMPLE_IMAGES=5

# ------------------------------------------------------------
# Notification Worker Configuration
# ------------------------------------------------------------
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_POLL_SECONDS=30
NOTIFICATION_WORKERS=1
